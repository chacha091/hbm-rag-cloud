pipeline {
    agent any

    environment {
        REGISTRY_HOST = 'amdp-registry.skala-ai.com'
        REGISTRY_PROJECT = 'skala26a-ai2'

        BACKEND_IMAGE_NAME = 'sk057-backend'
        FRONTEND_IMAGE_NAME = 'sk057-frontend'

        K8S_NAMESPACE = 'skala3-ai2'

        HARBOR_CREDENTIALS = 'harbor-robot-skala26a-ai2'
        AWS_CREDENTIALS = 'aws-access-key-cred'
        AWS_REGION = 'ap-northeast-2'
        EKS_CLUSTER_NAME = 'skala-2025'
    }

    options {
        timestamps()
        disableConcurrentBuilds()
        buildDiscarder(logRotator(numToKeepStr: '20'))
    }

    stages {
        stage('Checkout') {
            steps {
                checkout scm
            }
        }

        stage('Set Image Tag') {
            steps {
                script {
                    env.GIT_COMMIT_SHORT = sh(
                        script: 'git rev-parse --short HEAD',
                        returnStdout: true
                    ).trim()

                    env.IMAGE_TAG = "${BUILD_NUMBER}-${GIT_COMMIT_SHORT}"

                    env.BACKEND_IMAGE = "${REGISTRY_HOST}/${REGISTRY_PROJECT}/${BACKEND_IMAGE_NAME}:${IMAGE_TAG}"
                    env.FRONTEND_IMAGE = "${REGISTRY_HOST}/${REGISTRY_PROJECT}/${FRONTEND_IMAGE_NAME}:${IMAGE_TAG}"

                    env.BACKEND_IMAGE_LATEST = "${REGISTRY_HOST}/${REGISTRY_PROJECT}/${BACKEND_IMAGE_NAME}:latest"
                    env.FRONTEND_IMAGE_LATEST = "${REGISTRY_HOST}/${REGISTRY_PROJECT}/${FRONTEND_IMAGE_NAME}:latest"
                }
            }
        }

        stage('Code Build') {
            steps {
                sh '''
                    if command -v python3 >/dev/null 2>&1; then
                        python3 -m py_compile backend_api.py rag_backend_full.py
                    elif command -v python >/dev/null 2>&1; then
                        python -m py_compile backend_api.py rag_backend_full.py
                    else
                        echo "Python is not installed on this Jenkins agent."
                        exit 1
                    fi
                '''
            }
        }

        stage('Docker Build') {
            steps {
                sh '''
                    docker build -t ${BACKEND_IMAGE} -t ${BACKEND_IMAGE_LATEST} -f Dockerfile.backend .
                    docker build -t ${FRONTEND_IMAGE} -t ${FRONTEND_IMAGE_LATEST} -f Dockerfile.frontend .
                '''
            }
        }

        stage('Push Image to Harbor') {
            steps {
                withCredentials([usernamePassword(
                    credentialsId: "${HARBOR_CREDENTIALS}",
                    usernameVariable: 'HARBOR_USER',
                    passwordVariable: 'HARBOR_PASS'
                )]) {
                    sh '''
                        echo "${HARBOR_PASS}" | docker login ${REGISTRY_HOST} -u "${HARBOR_USER}" --password-stdin
                        docker push ${BACKEND_IMAGE}
                        docker push ${BACKEND_IMAGE_LATEST}
                        docker push ${FRONTEND_IMAGE}
                        docker push ${FRONTEND_IMAGE_LATEST}
                        docker logout ${REGISTRY_HOST}
                    '''
                }
            }
        }

        stage('Deploy to EKS') {
            steps {
                withCredentials([usernamePassword(
                    credentialsId: "${AWS_CREDENTIALS}",
                    usernameVariable: 'AWS_ACCESS_KEY_ID',
                    passwordVariable: 'AWS_SECRET_ACCESS_KEY'
                )]) {
                    sh '''
                        export AWS_ACCESS_KEY_ID=${AWS_ACCESS_KEY_ID}
                        export AWS_SECRET_ACCESS_KEY=${AWS_SECRET_ACCESS_KEY}
                        export AWS_DEFAULT_REGION=${AWS_REGION}

                        aws eks update-kubeconfig --region ${AWS_REGION} --name ${EKS_CLUSTER_NAME}

                        kubectl -n ${K8S_NAMESPACE} set image deployment/sk057-backend \
                          backend=${BACKEND_IMAGE}

                        kubectl -n ${K8S_NAMESPACE} set image deployment/sk057-frontend \
                          frontend=${FRONTEND_IMAGE}

                        kubectl -n ${K8S_NAMESPACE} rollout status deployment/sk057-backend --timeout=300s
                        kubectl -n ${K8S_NAMESPACE} rollout status deployment/sk057-frontend --timeout=300s

                        kubectl get pods -n ${K8S_NAMESPACE}
                    '''
                }
            }
        }
    }

    post {
        success {
            echo "CI/CD pipeline succeeded."
        }
        failure {
            echo "CI/CD pipeline failed."
        }
        always {
            sh 'docker image prune -f || true'
        }
    }
}
